# the-decommissioner — example environment file
#
# Copy to .env and adjust for your setup.
# The backend reads this file automatically via pydantic-settings.
# For Docker, docker-compose reads it from the project root.
#
# Values shown are the defaults; uncomment and change what you need.

# ---------------------------------------------------------------------------
# Data directory
# Holds the SQLite database, job logs, and iOS staging directories.
# The directory is created automatically on first run.
# ---------------------------------------------------------------------------
# DATA_DIR=~/.decommissioner

# ---------------------------------------------------------------------------
# Server binding
# Change HOST to 0.0.0.0 to accept connections from other machines or Docker.
# ---------------------------------------------------------------------------
# HOST=127.0.0.1
# PORT=8000

# ---------------------------------------------------------------------------
# Log level
# Passed to uvicorn. Options: debug, info, warning, error, critical.
# ---------------------------------------------------------------------------
# LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Restic repository password
#
# The app never stores this value. When you configure a storage target in
# the UI, you specify the *name* of the env var that holds the password
# (default: RESTIC_PASSWORD). The app passes it through to restic at runtime.
#
# You can define multiple vars if you use multiple repositories:
#   RESTIC_PASSWORD=secret-for-default-repo
#   RESTIC_PASSWORD_OFFSITE=secret-for-offsite-repo
#
# Then set the matching var name in each storage target's settings.
# ---------------------------------------------------------------------------
RESTIC_PASSWORD=changeme
